  "item": [
    {
      "name": "user by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseurl}}/api/users/1",
          "host": [
            "{{baseurl}}"
          ],
          "path": [
            "api",
            "users",
            "1"
          ]
        }
      },
      "response": []
    },
    {
      "name": "create user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () { pm.response.to.have.status(201); });\r",
              "pm.test(\"Response has ID and we save it\",function(){\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.exist;\r",
              "    pm.environment.set(\"userId\", jsonData.id); // Save the ID for future use\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\" : \"Bindu\",\r\n    \"job\" : \"Test Analyst\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseurl}}/api/users",
          "host": [
            "{{baseurl}}"
          ],
          "path": [
            "api",
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "created user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Chaining worked - we accept 200 or 404 on mock API\", () => {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);\r",
              "});\r",
              "\r",
              "pm.test(\"Request URL used the saved userId\", () => {\r",
              "    const url = pm.request.url.toString();\r",
              "    const savedId = pm.environment.get(\"userId\");\r",
              "    pm.expect(url).to.include(savedId);\r",
              "    console.log(\"Called URL with ID:\", savedId); // Check console to prove it\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseurl}}/api/users/{{userId}}",
          "host": [
            "{{baseurl}}"
          ],
          "path": [
            "api",
            "users",
            "{{userId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "invalid user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"404 for invalid user\", () => {\r",
              "    pm.response.to.have.status(404);\r",
              "});\r",
              "\r",
              "pm.test(\"Error response is fast\", () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
